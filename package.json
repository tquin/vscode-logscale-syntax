{
  "name": "logscale-syntax",
  "displayName": "LogScale Syntax Highlighting",
  "description": "A syntax highlighter extension for LogScale Query Langauge (LQL), formerly Humio.",
  "icon": "images/logo.png",
  "publisher": "tquin",
  "version": "0.2.2",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "deploy": "vsce publish --yarn",
    "test": "vscode-test",
    "vscode:prepublish": "yarn compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "logscale",
        "aliases": [
          "Logscale Query Language",
          "CrowdStrike Query Language",
          "Humio",
          "logscale"
        ],
        "extensions": [
          ".lql",
          ".logscale",
          ".humio",
          ".cql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "logscale",
        "scopeName": "source.logscale",
        "path": "./syntaxes/logscale.tmLanguage.json"
      },
      {
        "injectTo": [
          "source.yaml"
        ],
        "scopeName": "source.yaml.injection",
        "path": "./syntaxes/yaml-injection.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.inline.logscale": "logscale"
        }
      }
    ],
    "configuration": {
      "title": "LogScale Syntax Highlighting",
      "properties": {
        "logscale-syntax.yamlHighlightedKeys": {
          "type": "array",
          "default": [
            "queryString"
          ],
          "items": {
            "type": "string"
          },
          "markdownDescription": "List of YAML keys that should apply LQL/CQL syntax highlighting. Changes require window reload."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/vscode": "~1.95.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tquin/vscode-logscale-syntax.git"
  }
}
