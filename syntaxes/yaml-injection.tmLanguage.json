{
  "scopeName": "source.yaml.injection",
  "injectionSelector": "L:source.yaml",
  "patterns": [
    {
      "comment": "Block scalar style (| or >)",
      "begin": "(?i)(queryString):\\s*(?:(\\|)|(>))([1-9])?([-+])?\\s+$",
      "beginCaptures": {
        "1": {
          "name": "entity.name.tag.yaml"
        },
        "2": {
          "name": "keyword.control.flow.block-scalar.literal.yaml"
        },
        "3": {
          "name": "keyword.control.flow.block-scalar.folded.yaml"
        },
        "4": {
          "name": "constant.numeric.indentation-indicator.yaml"
        },
        "5": {
          "name": "storage.modifier.chomping-indicator.yaml"
        }
      },
      "end": "^(?=\\S)|(?!\\G)",
      "patterns": [
        {
          "begin": "(?>^|\\G)([ ]+)(?! )",
          "end": "^(?!\\1|\\s*$)",
          "name": "meta.embedded.block.logscale",
          "patterns": [
            {
              "include": "source.logscale"
            }
          ]
        }
      ]
    },
    {
      "comment": "Inline/flow style (quoted string)",
      "begin": "(?i)(queryString):\\s*(\")",
      "beginCaptures": {
        "1": {
          "name": "entity.name.tag.yaml"
        },
        "2": {
          "name": "punctuation.definition.string.begin.yaml"
        }
      },
      "end": "(?<!\\\\)((?:\\\\\\\\)*)\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.yaml"
        }
      },
      "name": "meta.embedded.inline.logscale string.quoted.double.yaml",
      "patterns": [
        {
          "include": "source.logscale"
        }
      ]
    },
    {
      "comment": "Inline/flow style (unquoted)",
      "begin": "(?i)(queryString):\\s+(?![\"'|>])",
      "beginCaptures": {
        "1": {
          "name": "entity.name.tag.yaml"
        }
      },
      "end": "$|(?=\\s+#)",
      "name": "meta.embedded.inline.logscale",
      "patterns": [
        {
          "include": "source.logscale"
        }
      ]
    }
  ]
}
